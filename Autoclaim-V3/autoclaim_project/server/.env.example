# ============================================================
# AutoClaim — Environment Variables Template
# Copy this file to .env and fill in the values.
# !! NEVER commit .env to git !!
# ============================================================

# --- Database ---
# For local dev: sqlite:///./autoclaim.db
# For production (Neon.tech): postgresql://user:pass@host/dbname?sslmode=require
DATABASE_URL=sqlite:///./autoclaim.db

# --- Auth ---
# Generate a strong random key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_before_production

# --- AI APIs ---
# Get from: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# --- AI Mode ---
# Options:
#   full        → YOLO + EasyOCR + Gemini (requires torch, GPU recommended)
#   yolo_only   → YOLO only, no EasyOCR (runs on CPU, for Render free tier)
#   groq_only   → Groq cloud AI only, no local models (lightest, for Render)
AI_MODE=yolo_only

# --- CORS ---
# Production: set to your HuggingFace Space frontend URL, e.g. https://autoclaim-v3.vercel.app
FRONTEND_URL=http://localhost:3000

# NOTE: PRICE_API_URL no longer needed — Price API is merged into this app as app/price_api/

