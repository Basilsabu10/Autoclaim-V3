# ============================================================
# AutoClaim — Frontend Environment Variables Template
# Copy this to .env.local for local dev, or set in Vercel dashboard.
# !! NEVER commit .env.local to git !!
# ============================================================

# Backend API URL
# Local dev:   http://localhost:8000
# Production:  https://autoclaim-api.onrender.com  (your Render URL)
VITE_API_URL=http://localhost:8000

# Price API URL
# Local dev:   http://localhost:8001
# Production:  https://autoclaim-price-api.onrender.com  (your Render URL)
VITE_PRICE_API_URL=http://localhost:8001
